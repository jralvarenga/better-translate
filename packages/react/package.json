{
  "name": "@better-translate/react",
  "version": "0.0.0",
  "description": "React context and hooks for Better Translate.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "check-types": "tsc --noEmit",
    "test": "bun test src/**/*.test.tsx"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "better-translate": "0.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "react-test-renderer": "^19.2.0"
  },
  "keywords": [
    "i18n",
    "l10n",
    "react",
    "translations",
    "typescript"
  ]
}
