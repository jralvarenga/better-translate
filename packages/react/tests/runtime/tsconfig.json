{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../..",
    "noEmit": true,
    "paths": {
      "@better-translate/core": ["../core/src/index.ts"],
      "@better-translate/core/server": ["../core/src/server.ts"]
    },
    "rootDir": "../..",
    "types": ["bun-types", "node", "react"]
  },
  "include": [
    "../../src/**/*.ts",
    "../../src/**/*.tsx",
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.d.ts"
  ],
  "exclude": ["../../dist", "../../node_modules"]
}
