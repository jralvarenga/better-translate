{
  "name": "@better-translate/md",
  "version": "0.0.0",
  "description": "Markdown and MDX helpers for Better Translate.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm,cjs --dts --clean",
    "check-types": "tsc --noEmit",
    "test": "bun test tests/runtime",
    "test:types": "tsc -p tests/types/tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "better-translate": "0.0.0",
    "gray-matter": "^4.0.3",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@repo/typescript-config": "*"
  },
  "keywords": [
    "i18n",
    "l10n",
    "markdown",
    "mdx",
    "translations",
    "typescript"
  ]
}
