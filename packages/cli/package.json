{
  "name": "@better-translate/cli",
  "version": "2.0.0",
  "description": "AI-powered translation generation CLI for Better Translate.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bt": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/config.ts src/bin.ts --format esm --clean && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "test": "bun test tests/runtime",
    "test:types": "tsc -p tests/types/tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jralvarenga/better-translate.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/jralvarenga/better-translate/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/jralvarenga/better-translate/issues"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "ai": "^6.0.116",
    "@better-translate/core": "^2.0.0",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "ora": "^8.2.0",
    "picocolors": "^1.1.1",
    "typescript": "5.9.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^24.5.2"
  },
  "keywords": [
    "ai",
    "cli",
    "i18n",
    "l10n",
    "translations",
    "typescript"
  ]
}
