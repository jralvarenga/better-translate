{
  "name": "@better-translate/vscode",
  "displayName": "Better Translate",
  "description": "Go to Definition support for better-translate translation keys.",
  "version": "0.0.1",
  "private": true,
  "publisher": "better-translate",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "configuration": {
      "title": "Better Translate",
      "properties": {
        "betterTranslate.defaultLocale": {
          "type": "string",
          "default": "",
          "description": "Override the default locale (e.g. 'en'). Leave empty to auto-detect."
        },
        "betterTranslate.localesDir": {
          "type": "string",
          "default": "",
          "description": "Override the path to the locales directory (relative to workspace root)."
        },
        "betterTranslate.translatorFunctionNames": {
          "type": "array",
          "default": [
            "t"
          ],
          "description": "Function names to treat as translation calls."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "check-types": "tsc --noEmit",
    "dev": "node esbuild.mjs --watch",
    "test": "bun test tests/runtime",
    "test:types": "tsc -p tests/types/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0"
  }
}
