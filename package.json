{
  "name": "better-translate-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@better-translate/core --filter=@better-translate/*",
    "dev": "turbo run dev --concurrency=20",
    "dev:landing": "turbo run dev --filter=landing",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check-types": "NODE_OPTIONS=--max-old-space-size=8192 turbo run check-types",
    "check-types:packages": "NODE_OPTIONS=--max-old-space-size=8192 turbo run check-types --filter=@better-translate/core --filter=@better-translate/*",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "release:pack": "node ./scripts/release-pack-check.mjs",
    "release:verify": "bun run build:packages && bun run test:packages && bun run release:pack",
    "release:publish": "changeset publish",
    "test": "bun run test:packages",
    "test:packages": "bun run test:packages:runtime && bun run test:packages:types",
    "test:packages:runtime": "bun run --filter='@better-translate/core' --filter='@better-translate/*' --if-present test",
    "test:packages:types": "bun run --filter='@better-translate/core' --filter='@better-translate/*' --if-present test:types"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.5.1",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.23",
  "workspaces": ["apps/*", "packages/*", "examples/*"]
}
