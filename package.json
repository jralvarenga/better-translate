{
  "name": "better-translate-workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=better-translate --filter=better-translate/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-types:packages": "turbo run check-types --filter=better-translate --filter=better-translate/*"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.23",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
