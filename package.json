{
  "name": "better-translate-workspace",
  "private": true,
  "version": "1.0.1",
  "keywords": ["agent-skill"],
  "scripts": {
    "build": "turbo run build",
    "build:landing": "turbo run build --filter=landing --only",
    "build:packages": "turbo run build --filter=@better-translate/core --filter=@better-translate/*",
    "dev": "turbo run dev --concurrency=20",
    "dev:landing": "turbo run dev --filter=landing",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:lockfile": "bun install --frozen-lockfile --dry-run",
    "changeset:enter-next": "changeset pre enter next",
    "changeset:exit-next": "changeset pre exit",
    "ci:version": "changeset version && bun install --no-frozen-lockfile",
    "ci:release": "node ./scripts/verify-npm-auth.mjs && bun run release:verify && bun run release:publish",
    "check-types": "NODE_OPTIONS=--max-old-space-size=8192 turbo run check-types",
    "changeset": "changeset",
    "release:pack": "node ./scripts/release-pack-check.mjs",
    "release:verify": "bun run build:packages && bun run test:packages && bun run release:pack",
    "release:publish": "changeset publish",
    "release:github": "node ./scripts/create-github-releases.mjs",
    "release:tags": "node ./scripts/create-release-tags.mjs",
    "test": "bun run test:packages",
    "test:packages": "bun run test:packages:runtime",
    "test:packages:runtime": "bun run --filter='@better-translate/core' --filter='@better-translate/*' --if-present test",
    "test:packages:types": "turbo run test:types --filter=@better-translate/core --filter='@better-translate/*'"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.5.1",
    "turbo": "^2.8.17",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.23",
  "workspaces": ["apps/*", "packages/*", "examples/*"]
}
